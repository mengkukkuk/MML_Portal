# Copy to .env and fill in real values. Do NOT commit .env.

# --- Local PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# --- JWT ---
# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_EXPIRE_MIN=30
REFRESH_EXPIRE_DAYS=7
RESET_EXPIRE_MIN=30

# --- Account management ---
# Base URL of the frontend (used to build password-reset links in emails).
APP_BASE_URL=http://localhost:5173
MIN_PASSWORD_LEN=8

# --- SMTP (password-reset email delivery) ---
# Leave SMTP_HOST empty to log the reset link instead of sending (dev mode).
# Fill these in to send real email via your SMTP relay.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# From header; defaults to SMTP_USER if blank. Quoted display name is fine:
#   SMTP_FROM="SCADA <no-reply@example.com>"
SMTP_FROM=
# Connection security: starttls (port 587) | ssl (port 465) | none
SMTP_SECURITY=starttls
SMTP_TIMEOUT=10
