# Copy to .env.local and edit
# Base URL for the scada-api backend. Vite dev server proxies /api → 127.0.0.1:8088 by default.
VITE_API_BASE=/api

# Grafana embed settings (set after Grafana is installed)
VITE_GRAFANA_URL=http://localhost:3000
# Dashboard UID from Grafana URL: /d/<UID>/dashboard-name
VITE_GRAFANA_DASHBOARD_UID=
# Dashboard slug from Grafana URL: /d/<UID>/<slug>
VITE_GRAFANA_DASHBOARD_SLUG=
