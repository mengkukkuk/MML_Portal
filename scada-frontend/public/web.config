<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS configuration for the SCADA frontend deployed at the ROOT of a dedicated site.

  Prerequisites on the IIS host:
    - URL Rewrite Module 2.x          https://www.iis.net/downloads/microsoft/url-rewrite
    - Application Request Routing 3.x https://www.iis.net/downloads/microsoft/application-request-routing
        After install: open IIS Manager > server node > Application Request Routing Cache
        > Server Proxy Settings > tick "Enable proxy" > Apply.
    - WebSocket Protocol feature      (Server Manager > Add Roles and Features > Web Server > WebSocket Protocol)

  Deployment:
    - Create a Site in IIS Manager with this folder as the physical path.
    - The application pool may be "No Managed Code"; this is a static SPA.

  Backend (scada-api) must be reachable from the IIS host at http://127.0.0.1:8088.

  Optional - forwarded headers:
    The rewrite rules below do NOT set X-Forwarded-Host / X-Forwarded-Proto. If the backend
    needs to know the public host/scheme, register the variables once on the host:
      appcmd set config /section:system.webServer/rewrite/allowedServerVariables ^
        /+"[name='HTTP_X_FORWARDED_HOST']" /commit:apphost
      appcmd set config /section:system.webServer/rewrite/allowedServerVariables ^
        /+"[name='HTTP_X_FORWARDED_PROTO']" /commit:apphost
    Then add a <serverVariables> block to each proxy rule. Without registration, setting
    these inside a rule causes HTTP 500.52 on every request.
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- 1. Reverse-proxy WebSocket traffic to the scada-api backend.
             ARR auto-detects the WebSocket upgrade; use http:// (not ws://) here. -->
        <rule name="Proxy /ws to backend" stopProcessing="true">
          <match url="^ws(/.*)?$" />
          <action type="Rewrite" url="http://127.0.0.1:8088/ws{R:1}" />
        </rule>

        <!-- 2. Reverse-proxy REST API traffic to the scada-api backend. -->
        <rule name="Proxy /api to backend" stopProcessing="true">
          <match url="^api/(.*)$" />
          <action type="Rewrite" url="http://127.0.0.1:8088/api/{R:1}" />
        </rule>

        <!-- 3. SPA history-mode fallback: anything that isn't a real file/dir
             and isn't proxied above is served by index.html so vue-router can pick it up. -->
        <rule name="SPA fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
            <add input="{REQUEST_URI}" pattern="^/(api|ws)(/|$)" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.html" />
        </rule>
      </rules>
    </rewrite>

    <security>
      <requestFiltering>
        <!-- Modern JS bundles can exceed the 30 MB default; bump to 100 MB. -->
        <requestLimits maxAllowedContentLength="104857600" />
      </requestFiltering>
    </security>

    <!-- Let backend responses (e.g. 404 from /api) pass through untouched. -->
    <httpErrors errorMode="PassThrough" />

    <!-- MIME types Vite/modern bundlers can emit that older IIS installs miss. -->
    <staticContent>
      <remove fileExtension=".mjs" />
      <mimeMap fileExtension=".mjs" mimeType="application/javascript" />
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>
  </system.webServer>

  <!-- Hashed asset filenames are safe to cache forever. -->
  <location path="assets">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
      </staticContent>
    </system.webServer>
  </location>

  <!-- index.html must NOT be cached, or returning users will get a stale shell
       pointing at hashed bundles that no longer exist after a deploy. -->
  <location path="index.html">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="DisableCache" />
      </staticContent>
    </system.webServer>
  </location>
</configuration>